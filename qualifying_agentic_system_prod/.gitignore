# Outputs (run-specific results)
outputs/

# Input data (CSVs with domain lists)
inputs/*.csv
inputs/**/*.csv
!inputs/.gitkeep

# Temp/scratch files
temp/
*.pyc
__pycache__/
.DS_Store

# Environment
.env

# Data files
*.csv
*.txt
!requirements.txt

# Testing outputs
testing/*/results/
testing/*/outputs*/
testing/*/samples/

# Run-specific specs and configs (keep templates and examples)
configs/specs/analysis/[a-z]*_*.json
!configs/specs/analysis/insurance_claims_qualification.json
configs/runs/[a-z]*_*.yaml
!configs/runs/example_*.yaml
!configs/runs/TEMPLATE.yaml
