{
    "spec_name": "saas_selector_v1",
    "description": "Heuristic selector for B2B SaaS companies to identify high-value context pages.",
    "strategies": [
        {
            "id": "main",
            "label": "Main Page",
            "patterns": [
                "/"
            ],
            "priority": 100,
            "limit": 1
        },
        {
            "id": "about",
            "label": "About Pages",
            "patterns": [
                "/about",
                "/company",
                "/mission",
                "/story",
                "/our-story",
                "/who-we-are"
            ],
            "priority": 90,
            "limit": 5
        },
        {
            "id": "product",
            "label": "Product Pages",
            "patterns": [
                "/product",
                "/features",
                "/platform",
                "/solutions",
                "/services"
            ],
            "priority": 80,
            "limit": 5
        },
        {
            "id": "job_postings",
            "label": "Job Postings (Individual)",
            "patterns": [
                "/jobs/",
                "/careers/",
                "/openings/",
                "/join-us/",
                "/role/",
                "/position/"
            ],
            "priority": 70,
            "limit": 5
        }
    ],
    "ignore_patterns": [
        "/login",
        "/signin",
        "/signup",
        "/register",
        "/legal",
        "/privacy",
        "/terms",
        "/security",
        "/status",
        "/support",
        "/help",
        "/docs",
        "/api",
        "/blog/page/",
        "/news/page/",
        "/wp-content",
        "/cdn-cgi"
    ],
    "max_pages": 5
}